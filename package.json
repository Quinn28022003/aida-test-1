{
  "name": "aida",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:migration:new": "supabase migration new",
    "migrate:up": "cross-env NODE_ENV=development supabase db push",
    "migrate:up:force": "cross-env NODE_ENV=development supabase db push --include-all",
    "migrate:down": "cross-env NODE_ENV=development supabase migration down --linked --last 1",
    "migrate:status": "cross-env NODE_ENV=development supabase migration list",
    "migrate:up:prod": "cross-env NODE_ENV=production supabase db push",
    "migrate:up:force:prod": "cross-env NODE_ENV=production supabase db push --include-all",
    "migrate:down:prod": "cross-env NODE_ENV=production supabase migration down --linked --last 1",
    "migrate:status:prod": "cross-env NODE_ENV=production supabase migration list",
    "db:reset": "echo \"db:reset is disabled for cloud workflow. Use local Supabase only.\" && exit 1",
    "db:types": "supabase gen types typescript --project-id sahsneeooeathuurbxmy --schema public > packages/db/src/database-generated.types.ts.tmp && mv packages/db/src/database-generated.types.ts.tmp packages/db/src/database-generated.types.ts",
    "db:types:local": "supabase gen types typescript --local --schema public > packages/db/src/database-generated.types.ts.tmp && mv packages/db/src/database-generated.types.ts.tmp packages/db/src/database-generated.types.ts",
    "db:validate": "pnpm db:types && git diff --exit-code packages/db/src/database-generated.types.ts",
    "db:validate:local": "pnpm db:types:local && git diff --exit-code packages/db/src/database-generated.types.ts",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:chat": "turbo run test --filter=@aida/chat",
    "test:vault": "turbo run test --filter=@aida/vault",
    "test:api-gateway": "turbo run test --filter=@aida/api-gateway",
    "test:background-service": "turbo run test --filter=@aida/background-service",
    "test:packages": "turbo run test --filter='./packages/*'",
    "test:coverage": "turbo run test:coverage && node scripts/githubActions/merge-coverage.mjs",
    "test:watch": "vitest --workspace vitest.workspace.ts",
    "prerls:generate": "pnpm --filter @aida/contracts build",
    "rls:generate": "node scripts/rls/generate-rls-sql.mjs",
    "prerls:sync": "pnpm --filter @aida/contracts build",
    "rls:sync": "node scripts/rls/sync-rls-sql.mjs",
    "rls:test": "node scripts/rls/test/run-tests.mjs",
    "prepare": "husky",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json,yml,yaml}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "supabase": "^2.98.2",
    "turbo": "^2.9.14",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=24"
  }
}
