{
  "name": "@aida/config",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./public": "./src/env/public.ts",
    "./server": "./src/env/server.ts",
    "./worker": "./src/env/worker.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --config vitest.config.ts",
    "test:coverage": "vitest run --passWithNoTests --config vitest.config.ts --coverage"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
