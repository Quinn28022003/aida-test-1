# App runtime
PORT=3003

# Supabase and database
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://user:password@localhost:5432/aida

# AWS credentials
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Bedrock models
BEDROCK_MODEL_SUMMARIZER=arn:aws:bedrock:ap-southeast-2:182399702812:inference-profile/global.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MODEL_EMBEDDING=amazon.titan-embed-text-v2:0

# Logging and debug
LOG_LEVEL=info
DEBUG=false
AIDA_DEBUG_TRACE=false
