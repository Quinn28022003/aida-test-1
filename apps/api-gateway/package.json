{
  "name": "@aida/api-gateway",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --config vitest.config.ts",
    "test:coverage": "vitest run --passWithNoTests --config vitest.config.ts --coverage"
  },
  "dependencies": {
    "@aida/config": "workspace:^",
    "@aida/shared": "workspace:^",
    "@hono/node-server": "^2.0.2",
    "dotenv": "^17.4.2",
    "hono": "^4.12.19"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.22.0"
  }
}
